---
// 定义你的极客状态弹幕内容（你可以随时修改这些文案）
const messages = [
  "🐧 Linux Kernel 编译中 ",
  "🤖 Neuro-sama 复刻进度: 12%",
  "🔧 Droidspaces 容器调试",
  "📡 正在连接 DeepSeek V4 API...",
  "⚠️ FUSE 文件系统 symlink 限制已绕过",
  "💡 极客精神：掌控底层，拒绝黑盒",
  "🧠 Python 异步 IO 学习中",
];

// 复制一份数组，用于实现视觉上的无缝首尾相接
const loopMessages = [...messages, ...messages];
---

<div class="w-full bg-gray-950 border-y border-gray-800 py-3 overflow-hidden relative shadow-[0_4px_20px_-4px_rgba(0,255,0,0.1)]">
  <!-- 滚动容器 -->
  <div class="flex whitespace-nowrap animate-marquee">
    {loopMessages.map((msg) => (
      <span class="mx-8 text-sm font-mono text-green-400 tracking-wider flex items-center gap-2 opacity-80 hover:opacity-100 transition-opacity">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.8)]"></span>
        {msg}
      </span>
    ))}
  </div>
</div>