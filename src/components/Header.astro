---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="right-section">
			<div class="internal-links">
				<HeaderLink href="/">
					<span class="nav-zh">首页</span>
					<span class="nav-en">Home</span>
				</HeaderLink>
				<HeaderLink href="/blog">
					<span class="nav-zh">博客</span>
					<span class="nav-en">Blog</span>
				</HeaderLink>
				<HeaderLink href="/about">
					<span class="nav-zh">关于</span>
					<span class="nav-en">About</span>
				</HeaderLink>
			</div>
		</div>
	</nav>
	<button id="theme-toggle" onclick="window.__toggleTheme()" title="切换主题">
		<span id="theme-toggle-icon">☀️</span>
	</button>
</header>

<script>
	(function(){
		function syncBtn(){
			var dark = document.body.classList.contains('dark-mode');
			var btn = document.getElementById('theme-toggle-icon');
			if(btn) btn.textContent = dark ? '🌙' : '☀️';
		}
		document.addEventListener('DOMContentLoaded', syncBtn);
		var orig = window.__toggleTheme;
		if(orig){
			window.__toggleTheme = function(){
				orig();
				syncBtn();
			};
		}
	})();
</script>

<style>
	header {
		position: relative;
		margin: 0;
		padding: 0 1em;
		background: rgba(255, 255, 255, 0.55);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
	}
	#theme-toggle {
		position: absolute;
		bottom: -45px;
		right: 1.5em;
		z-index: 10000;
		background: rgba(255,255,255,0.8);
		border: 1px solid rgba(0,0,0,0.1);
		border-radius: 50%;
		width: 38px;
		height: 38px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 18px;
		box-shadow: 0 2px 8px rgba(0,0,0,0.15);
		transition: transform 0.2s, background 0.2s;
	}
	#theme-toggle:hover {
		transform: scale(1.15);
		background: rgba(255,255,255,1);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.right-section {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.nav-zh {
		font-size: 1.1em;
		font-weight: 600;
	}
	.nav-en {
		font-size: 0.75em;
		font-weight: 400;
		margin-left: 0.25em;
		opacity: 0.7;
	}
</style>