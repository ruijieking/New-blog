---
import { Image } from 'astro:assets';
import ruijiking from '../assets/ruijiking.jpeg';
---

<div class="m-8 p-20 rounded-3xl flex flex-col items-start gap-6">
	<a href="/" class="theme-card block w-full max-w-xl p-8 rounded-2xl backdrop-blur-xl shadow-2xl hover:scale-105 transition-transform duration-300 cursor-pointer no-underline">
		<div class="flex flex-col items-start gap-5">
			<Image src={ruijiking} alt="" class="w-52 h-52 rounded-full object-cover shadow-lg" />
			<div class="flex gap-4">
				<span class="theme-btn px-6 py-2 text-lg font-semibold rounded-full shadow-lg inline-block">
					进入主页 →
				</span>
			</div>
		</div>
	</a>
</div>