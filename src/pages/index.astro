---
import '../styles/global.css'; 
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import WallpaperSwitcher from '../components/WallpaperSwitcher.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import ProfileImg from '../assets/ruijieking.jpg';
---

<!doctype html>
<html lang="zh" style="height: 100%; margin: 0; padding: 0;">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body style={`background-size: cover; background-position: center; background-repeat: no-repeat; background-attachment: fixed; min-height: 100vh; margin: 0; padding: 0;`}>
		<Header />
		<WallpaperSwitcher />
		<div class="flex justify-start items-start pl-12 pt-32 min-h-screen">
			<a href="/about" class="theme-card block w-full max-w-md p-8 rounded-2xl backdrop-blur-xl shadow-2xl hover:scale-105 transition-transform duration-300 cursor-pointer no-underline">
				<div class="flex flex-col items-center gap-5">
					<img src={ProfileImg.src} alt="头像" class="w-28 h-28 rounded-full object-cover border-4 border-white/30 shadow-lg" />
					<span class="theme-btn px-6 py-2 font-semibold rounded-full shadow-lg inline-block">
						进入主页 →
					</span>
				</div>
			</a>
		</div>
	</body>
</html>
