---
import '../styles/global.css'; 
import GeekTicker from '../components/GeekTicker.astro';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import WallpaperSwitcher from '../components/WallpaperSwitcher.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh" style="height: 100%; margin: 0; padding: 0;">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body style={`background-size: cover; background-position: center; background-repeat: no-repeat; background-attachment: fixed; min-height: 100vh; margin: 0; padding: 0;`}>
		<GeekTicker />
		<Header />
		<WallpaperSwitcher />
		<div class="m-8 p-12 rounded-3xl flex gap-6 flex-wrap">
			<a href="/about" class="theme-card block w-full max-w-lg p-8 rounded-2xl backdrop-blur-xl shadow-2xl hover:scale-105 transition-transform duration-300 cursor-pointer no-underline">
				<h2 class="text-2xl font-bold mb-4 flex items-center gap-2">
					<span>🧊</span> 关于我
				</h2>
				<p class="theme-desc leading-relaxed mb-6">
					点击这里了解更多
				</p>
				<div class="flex gap-4">
					<span class="theme-btn px-6 py-2 font-semibold rounded-full shadow-lg inline-block">
						进入主页 →
					</span>
				</div>
			</a>
		</div>
	</body>
</html>
